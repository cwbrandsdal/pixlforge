{
  "name": "pixelforge",
  "productName": "PixelForge",
  "version": "0.3.2",
  "description": "Desktop prompt-to-image batch generator powered by Codex CLI and the OpenAI Images API.",
  "main": "dist-electron/main.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cwbrandsdal/pixelforge.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:17851 && tsc -p electron/tsconfig.json && electron .\"",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "start": "npm run build && electron .",
    "gen-icon": "electron scripts/gen-icon.cjs",
    "dist": "npm run build && electron-builder --win --publish never",
    "release": "npm run build && electron-builder --win --publish always"
  },
  "author": "Christopher Brandsdal",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "no.cwb.pixelforge",
    "productName": "PixelForge",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*"
    ],
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "cwbrandsdal",
      "repo": "pixelforge"
    }
  }
}
